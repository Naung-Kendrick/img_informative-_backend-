{
  "compilerOptions": {
		"module": "commonjs",
		"target": "esnext",
		"types": ["node"],
		"esModuleInterop": true,
		"moduleResolution": "node",
		"sourceMap": true,
		"outDir": "dist",
		"allowJs": true,
		"lib": ["dom", "es6"],
		"skipLibCheck": true,
	},
  "include": [
    "src",
  ],
  "exclude": ["node_modules", "**/*.spec.ts"],
  "files": ["src/server.ts"]
}